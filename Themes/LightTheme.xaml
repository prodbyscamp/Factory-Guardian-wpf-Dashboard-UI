<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#f5f5f7"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#e5e5ea"/>
    <SolidColorBrush x:Key="MainBackgroundBrush" Color="#f5f5f7"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#ffffff"/>
    <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#f0f0f5"/>
    <SolidColorBrush x:Key="CardBackgroundSelectedBrush" Color="#e5e5ea"/>
    <SolidColorBrush x:Key="SubCardBackgroundBrush" Color="#f2f2f7"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1d1d1f"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#86868b"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#d1d1d6"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007aff"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#34c759"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#ffcc00"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#ff3b30"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#e5e5ea"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#c6c6c8"/>
    <SolidColorBrush x:Key="ChartLineBrush" Color="#aeaeb2"/>
    <LinearGradientBrush x:Key="ChartFillBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#e5e5ea" Offset="0"/>
        <GradientStop Color="#ffffff" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
