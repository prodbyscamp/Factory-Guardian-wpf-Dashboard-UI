<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#000000"/>
    <LinearGradientBrush x:Key="SidebarBackgroundBrush" StartPoint="0, 0" EndPoint="0.5, 1">
        <GradientStop Color="#0a0a0a" Offset="0"/>
        <GradientStop Color="#151515" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MainBackgroundBrush" StartPoint="0, 0" EndPoint="1, 1">
        <GradientStop Color="#141414" Offset="0"/>
        <GradientStop Color="#181818" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1c1c1e"/>
    <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#2c2c2e"/>
    <SolidColorBrush x:Key="CardBackgroundSelectedBrush" Color="#3a3a3c"/>
    <SolidColorBrush x:Key="SubCardBackgroundBrush" Color="#2c2c2e"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#f5f5f7"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#86868b"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#555555"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0a84ff"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#32d74b"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#ffd60a"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#ff453a"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#38383a"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#38383a"/>
    <SolidColorBrush x:Key="ChartLineBrush" Color="#5e5e62"/>
    <LinearGradientBrush x:Key="ChartFillBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#3a3a3c" Offset="0"/>
        <GradientStop Color="#1c1c1e" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
