<UserControl x:Class="FactoryGuardian.UserControls.InfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Name="infoCardf" Width="316" Height="140">
    <Border Margin="0 0 25 0" Background="{DynamicResource CardBackgroundBrush}" 
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="15">
        <Grid>
            <StackPanel Margin="30,0,0,30" VerticalAlignment="Bottom">
                <TextBlock Text="{Binding Path=Title, ElementName=infoCardf}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Path=Number, ElementName=infoCardf}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
