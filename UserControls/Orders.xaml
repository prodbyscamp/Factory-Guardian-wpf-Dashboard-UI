<UserControl x:Class="FactoryGuardian.UserControls.Orders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FactoryGuardian.UserControls"
             mc:Ignorable="d" Name="Order">

    <Border Padding="5" Margin="0 5" HorizontalAlignment="Stretch">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="10 0 0 0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Path=Title, ElementName=Order}" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Path=Desc, ElementName=Order}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 3 0 0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
