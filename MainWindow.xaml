<Window x:Class="FactoryGuardian.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Factory Guardian - Digital Twin Monitoring System"
        Height="740" Width="1280" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!--왼쪽 사이드바 -->
        <Border CornerRadius="10 0 0 10" Background="{DynamicResource SidebarBackgroundBrush}">
		
		
            <Grid>
                <!-- 좌측 강조선 -->
                <Border Width="1" HorizontalAlignment="Right" Background="{DynamicResource BorderBrush}"/>

                <StackPanel>
                    <!-- 로고 영역 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 40 0 0">
                        <Border CornerRadius="8" Width="36" Height="36" Background="{DynamicResource TextPrimaryBrush}">
                            <TextBlock Text="FG" Foreground="{DynamicResource WindowBackgroundBrush}" FontSize="20" FontWeight="Bold"
                                       TextAlignment="Center" VerticalAlignment="Center" Margin="1 0 0 1"/>
                        </Border>
                        <StackPanel Margin="12 0 0 0" VerticalAlignment="Center">
                            <TextBlock Text="FACTORY" FontSize="15" Margin="0 0 0 2" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="GUARDIAN" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>


                    <Separator Height="1" Margin="20 40 20 20" Background="{DynamicResource SeparatorBrush}"/>

                    <!-- 메뉴 -->
                    <RadioButton Style="{StaticResource NavButtonStyle}" Command="{Binding DashboardCommand}" IsChecked="True" GroupName="Nav">
                        <TextBlock Text="대시보드" Style="{StaticResource menuButtonText}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButtonStyle}" Command="{Binding RobotCommand}" GroupName="Nav">
                        <TextBlock Text="모니터링" Style="{StaticResource menuButtonText}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButtonStyle}" Command="{Binding EquipmentCommand}" GroupName="Nav">
                        <TextBlock Text="장비 관리" Style="{StaticResource menuButtonText}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButtonStyle}" Command="{Binding AlertsCommand}" GroupName="Nav">
                        <TextBlock Text="알람 내역" Style="{StaticResource menuButtonText}"/>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButtonStyle}" Command="{Binding MaintenanceCommand}" GroupName="Nav">
                        <TextBlock Text="유지보수" Style="{StaticResource menuButtonText}"/>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <!--메인컨텐츠 -->
        <Border CornerRadius="0 10 10 0" MouseDown="Border_MouseDown" Grid.Column="1" Background="{DynamicResource MainBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--상단 바 -->           
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!--다크모드. -->
                        <Button Content="◐" Margin="0 0 20 0" Width="30" Height="30" FontSize="16"
                                Style="{StaticResource topMenuButton}"
                                Command="{Binding ToggleThemeCommand}"/>

                        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.2" Duration="0:0:1.5" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="시스템 정상" Foreground="{DynamicResource SuccessBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Margin="8 0 10 0" VerticalAlignment="Center"/>

                        <Button Content="✕" Margin="10 0 0 0"
                                Style="{StaticResource topMenuButton}"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="20"/>
            </Grid>
        </Border>
    </Grid>
</Window>