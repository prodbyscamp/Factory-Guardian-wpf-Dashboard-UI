<UserControl x:Class="FactoryGuardian.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:uc="clr-namespace:FactoryGuardian.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1030">

    <UserControl.Resources>
        <Style x:Key="FilterButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="5 0 0 0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterButtonActive" TargetType="Button" BasedOn="{StaticResource FilterButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="200" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="대시보드" FontSize="28" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                    <TextBlock Text="{Binding CurrentDateKr}" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!--얘도 -->
        <Grid Grid.Row="1" Margin="50 10 15 30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <uc:InfoCard Grid.Column="0"
                         Title="작동 상태"
                         Number="{Binding SystemHealth}" />

            <uc:InfoCard Grid.Column="1"
                         Title="활성 알람"
                         Number="{Binding ActiveAlerts}" />

            <uc:InfoCard Grid.Column="2"
                         Title="총 생산량"
                         Number="{Binding TotalOutput}" />
        </Grid>

        <!-- 하단: 차트 + 알람 패널 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!--차트 -->
            <Border CornerRadius="16" Padding="30 22" Margin="50 0 10 35" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                        <TextBlock Text="차트" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!--Y축 -->
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                Margin="0 0 0 20" Grid.Row="1">
                        <TextBlock Text="60K" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 22"/>
                        <TextBlock Text="50K" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 22"/>
                        <TextBlock Text="40K" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 22"/>
                        <TextBlock Text="30K" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 22"/>
                        <TextBlock Text="20K" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 22"/>
                        <TextBlock Text="10K" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 22"/>
                        <TextBlock Text="0"   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>

                    <!-- 차트 본체 -->
                    <lvc:CartesianChart Grid.Row="1" Margin="40 0 0 20">
                        <lvc:CartesianChart.DataTooltip>
                            <lvc:DefaultTooltip Background="{DynamicResource CardBackgroundSelectedBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </lvc:CartesianChart.DataTooltip>
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis ShowLabels="False">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="0"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis MinValue="0" MaxValue="60000" ShowLabels="False">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="1" Stroke="{DynamicResource SeparatorBrush}"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
						<!--지금 주석처리 한 부분은 나중에 db에 붙이고 해야함. 대충은 붙여놨는데 어떻게 쓰는지 모르겠어요..
                        <lvc:CartesianChart.Series>
                            
							<lvc:LineSeries Stroke="{DynamicResource ChartLineBrush}" StrokeThickness="3"
                                            PointGeometrySize="0"
                                            Values="20000,17000,30000,14000,25000,40000,35000,45000,38000,50000"
                                            Fill="{DynamicResource ChartFillBrush}">
                            </lvc:LineSeries>
                        </lvc:CartesianChart.Series-->
                    </lvc:CartesianChart>
                </Grid>
            </Border>

            <!--최근 알람-->
            <Border Grid.Column="1" CornerRadius="16" Padding="0 22" Margin="10 0 47 35" Background="{DynamicResource CardBackgroundBrush}" 
			BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="22 0 0 15">
                        <TextBlock Text="최근 알람" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="5 4" HorizontalAlignment="Stretch">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="CornerRadius" Value="8"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Grid Width="42" Height="42" Margin="18 0 0 0">
                                                <Border CornerRadius="8" Background="{DynamicResource SubCardBackgroundBrush}">
                                                    <TextBlock Text="!" Foreground="{Binding Color}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" 
													VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <StackPanel Margin="14 0 0 0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Event}"
                                                           FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                                    <TextBlock Text="{Binding EquipmentName}"
                                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text=" · " FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Time}"
                                                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>