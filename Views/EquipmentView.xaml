<UserControl x:Class="FactoryGuardian.Views.EquipmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="50 35 0 30">
            <TextBlock Text="장비 관리" FontSize="26" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="50 0 50 40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 장비 리스트 -->
            <Border Grid.Column="0" CornerRadius="16" Padding="20" Margin="0 0 12 0" Background="{DynamicResource CardBackgroundBrush}" 
			BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 18">
                        <TextBlock Text="설비 목록" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Equipments}"
                             SelectedItem="{Binding SelectedEquipment, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0 0 0 10"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" 
											BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource CardBackgroundSelectedBrush}"/>
                                                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                                            <TextBlock Text="Model: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Text="{Binding ModelName}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Text=" | Type: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                                            <TextBlock Text="{Binding EquipmentType}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="1" CornerRadius="8" Padding="12 6" HorizontalAlignment="Right" VerticalAlignment="Center" Background="{DynamicResource SubCardBackgroundBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="0 0 6 0"/>
                                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 상세 패널 -->
            <Border Grid.Column="1" CornerRadius="16" Padding="25" Margin="12 0 0 0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid DataContext="{Binding SelectedEquipment}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="24" FontWeight="Bold" Margin="0 0 0 10"/>
                    <TextBlock Grid.Row="1" Text="{Binding Location}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0 0 0 20"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!--데이터섹션 -->
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="설치 일자" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 5"/>
                                    <TextBlock Text="{Binding InstallationDate, StringFormat=d}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="최근 점검일" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0 0 0 5"/>
                                    <TextBlock Text="{Binding LastMaintenanceDate, StringFormat=d}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <!--상태 -->
                            <Grid Margin="0 0 0 6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="상태" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding HealthScore, StringFormat={}{0:F0}점}" Foreground="{DynamicResource SuccessBrush}" FontSize="14" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar Value="{Binding HealthScore}" Maximum="100" Height="6" Margin="0 0 0 16" Foreground="{DynamicResource SuccessBrush}" Background="{DynamicResource SubCardBackgroundBrush}" BorderThickness="0">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Border CornerRadius="3" Background="{TemplateBinding Background}" Height="{TemplateBinding Height}">
                                            <Border x:Name="PART_Track">
                                                <Border x:Name="PART_Indicator" CornerRadius="3" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                                            </Border>
                                        </Border>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>

                            <!--상태-->
                            <Border Background="{DynamicResource SubCardBackgroundBrush}" CornerRadius="12" Padding="20" Margin="0 10 0 0">
                                <StackPanel>
                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="현재 온도" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Temperature, StringFormat={}{0:F1}°C}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="진동 (mm/s)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Vibration, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid Margin="0 0 0 12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="가동 시간 (h)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RunningHours, StringFormat={}{0:N0}h}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="최근 고장 횟수" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RecentFailureCount, StringFormat={}{0}회}" Foreground="{DynamicResource DangerBrush}" FontSize="14" FontWeight="Bold"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Button Content="유지보수 일정 추가" Margin="0 20 0 0" Padding="10 12" Background="{DynamicResource AccentBrush}" Foreground="#ffffff" FontWeight="Bold" BorderThickness="0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>